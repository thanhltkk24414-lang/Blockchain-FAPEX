# Sepolia deployment (used by Hardhat at repo root)
# Copy to contracts/.env — hardhat.config.js loads contracts/.env first.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# Etherscan — required for `npm run verify:sepolia`
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional: reuse existing USDC on Sepolia instead of deploying MockUSDC
# USDC_ADDRESS=0x...
